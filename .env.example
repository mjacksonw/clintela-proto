# =============================================================================
# Clintela Environment Configuration
# Copy this file to .env and update values for your environment
# =============================================================================

# =============================================================================
# Django Core Settings
# =============================================================================
DEBUG=True
PROTECTED=False
PROTECTED_GATE_PATH=letmein
SECRET_KEY=your-secret-key-here-change-in-production-min-50-chars-long
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL (required)
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://clintela:clintela@localhost:5434/clintela

# PostgreSQL Docker defaults (for docker-compose)
POSTGRES_USER=clintela
POSTGRES_PASSWORD=clintela
POSTGRES_DB=clintela

# =============================================================================
# Redis Configuration (for caching and Channels)
# =============================================================================
REDIS_URL=redis://localhost:6380/0

# =============================================================================
# LLM Configuration (Ollama Cloud for development)
# =============================================================================
# Ollama Cloud API (for prototyping)
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_BASE_URL=https://api.ollama.com/v1

# Ollama Embedding (local Ollama instance for RAG embeddings)
# Points to the Ollama container from docker-compose.services.yml
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434

# LangSmith tracing (opt-in — get API key at smith.langchain.com)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=clintela

# =============================================================================
# Twilio Configuration (for SMS/Voice - optional for local dev)
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# Email Configuration
# =============================================================================
# For development: log emails to console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production: SMTP configuration
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@clintela.com

# =============================================================================
# Security Settings
# =============================================================================
# Set to True in production
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG
LOG_DIR=logs

# =============================================================================
# Development Tools
# =============================================================================
# Django Debug Toolbar
DEBUG_TOOLBAR=True

# =============================================================================
# Optional: Sentry (for production error tracking)
# =============================================================================
# SENTRY_DSN=your-sentry-dsn-here

# =============================================================================
# Optional: AWS (for production file storage)
# =============================================================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=clintela-media
# AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable specific features
ENABLE_WEBSOCKETS=False
ENABLE_CELERY=False
ENABLE_SMS=False
ENABLE_VOICE=False
ENABLE_CLINICAL_DATA=True
